\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{generate\PYGZus{}balanced\PYGZus{}symmetric\PYGZus{}dataset}\PYG{p}{(}
    \PYG{n}{num\PYGZus{}samples}\PYG{p}{:} \PYG{n+nb}{int} \PYG{o}{=} \PYG{l+m+mi}{8000}\PYG{p}{,}
    \PYG{n}{positive\PYGZus{}ratio}\PYG{p}{:} \PYG{n+nb}{float} \PYG{o}{=} \PYG{l+m+mf}{0.6}\PYG{p}{,}
    \PYG{n}{vocab\PYGZus{}size}\PYG{p}{:} \PYG{n+nb}{int} \PYG{o}{=} \PYG{l+m+mi}{60}\PYG{p}{,}
    \PYG{n}{min\PYGZus{}half\PYGZus{}len}\PYG{p}{:} \PYG{n+nb}{int} \PYG{o}{=} \PYG{l+m+mi}{3}\PYG{p}{,}
    \PYG{n}{max\PYGZus{}half\PYGZus{}len}\PYG{p}{:} \PYG{n+nb}{int} \PYG{o}{=} \PYG{l+m+mi}{7}\PYG{p}{,}
    \PYG{n}{noise\PYGZus{}len}\PYG{p}{:} \PYG{n+nb}{int} \PYG{o}{=} \PYG{l+m+mi}{1}\PYG{p}{,}
    \PYG{n}{seed}\PYG{p}{:} \PYG{n+nb}{int} \PYG{o}{=} \PYG{l+m+mi}{42}
\PYG{p}{):}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{    Generate a synthetic sequence classification dataset with controllable class balance.}

\PYG{l+s+sd}{    The dataset is designed for sequence similarity classification:}
\PYG{l+s+sd}{        \PYGZhy{} Class 1 (Positive): Right half is approximately the reverse of the left half}
\PYG{l+s+sd}{        \PYGZhy{} Class 0 (Negative): Right half is random (dissimilar)}

\PYG{l+s+sd}{    Each sequence structure:}
\PYG{l+s+sd}{        [ left | noise | right ]}


\PYG{l+s+sd}{    Parameters}
\PYG{l+s+sd}{    num\PYGZus{}samples : int}
\PYG{l+s+sd}{        Total number of sequences to generate.}

\PYG{l+s+sd}{    positive\PYGZus{}ratio : float}
\PYG{l+s+sd}{        Proportion of positive (symmetric) samples.}
\PYG{l+s+sd}{        Example:}
\PYG{l+s+sd}{            0.5 → 50\PYGZpc{} positive / 50\PYGZpc{} negative}
\PYG{l+s+sd}{            0.6 → 60\PYGZpc{} positive / 40\PYGZpc{} negative}

\PYG{l+s+sd}{    vocab\PYGZus{}size : int}
\PYG{l+s+sd}{        Number of unique tokens in vocabulary.}
\PYG{l+s+sd}{        Token index 0 is reserved for padding (not used here).}

\PYG{l+s+sd}{    min\PYGZus{}half\PYGZus{}len : int}
\PYG{l+s+sd}{        Minimum length of the left (and right) segment.}

\PYG{l+s+sd}{    max\PYGZus{}half\PYGZus{}len : int}
\PYG{l+s+sd}{        Maximum length of the left (and right) segment.}

\PYG{l+s+sd}{    noise\PYGZus{}len : int}
\PYG{l+s+sd}{        Number of random tokens inserted between left and right segments.}

\PYG{l+s+sd}{    seed : int}
\PYG{l+s+sd}{        Random seed for reproducibility.}


\PYG{l+s+sd}{    Returns}
\PYG{l+s+sd}{    sequences : List[torch.Tensor]}
\PYG{l+s+sd}{        List of variable\PYGZhy{}length sequences.}

\PYG{l+s+sd}{    labels : torch.Tensor}
\PYG{l+s+sd}{        Tensor of shape (num\PYGZus{}samples,) containing class labels (0 or 1).}
\PYG{l+s+sd}{    \PYGZdq{}\PYGZdq{}\PYGZdq{}}


    \PYG{n}{random}\PYG{o}{.}\PYG{n}{seed}\PYG{p}{(}\PYG{n}{seed}\PYG{p}{)}
    \PYG{n}{torch}\PYG{o}{.}\PYG{n}{manual\PYGZus{}seed}\PYG{p}{(}\PYG{n}{seed}\PYG{p}{)}

    \PYG{n}{sequences} \PYG{o}{=} \PYG{p}{[]}
    \PYG{n}{labels} \PYG{o}{=} \PYG{p}{[]}

    \PYG{k}{for} \PYG{n}{\PYGZus{}} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{n}{num\PYGZus{}samples}\PYG{p}{):}

        \PYG{c+c1}{\PYGZsh{} Randomly choose length of left half}
        \PYG{n}{half\PYGZus{}len} \PYG{o}{=} \PYG{n}{random}\PYG{o}{.}\PYG{n}{randint}\PYG{p}{(}\PYG{n}{min\PYGZus{}half\PYGZus{}len}\PYG{p}{,} \PYG{n}{max\PYGZus{}half\PYGZus{}len}\PYG{p}{)}

        \PYG{c+c1}{\PYGZsh{} Generate left segment (avoid token 0 since it is padding)}
        \PYG{n}{left} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{randint}\PYG{p}{(}\PYG{l+m+mi}{1}\PYG{p}{,} \PYG{n}{vocab\PYGZus{}size}\PYG{p}{,} \PYG{p}{(}\PYG{n}{half\PYGZus{}len}\PYG{p}{,))}

        \PYG{c+c1}{\PYGZsh{} Generate small random noise segment}
        \PYG{n}{noise} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{randint}\PYG{p}{(}\PYG{l+m+mi}{1}\PYG{p}{,} \PYG{n}{vocab\PYGZus{}size}\PYG{p}{,} \PYG{p}{(}\PYG{n}{noise\PYGZus{}len}\PYG{p}{,))}

        \PYG{c+c1}{\PYGZsh{} Decide whether sample is Positive or Negative}
        \PYG{k}{if} \PYG{n}{random}\PYG{o}{.}\PYG{n}{random}\PYG{p}{()} \PYG{o}{\PYGZlt{}} \PYG{n}{positive\PYGZus{}ratio}\PYG{p}{:}

            \PYG{c+c1}{\PYGZsh{} Reverse the left sequence}
            \PYG{n}{right} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{flip}\PYG{p}{(}\PYG{n}{left}\PYG{p}{,} \PYG{n}{dims}\PYG{o}{=}\PYG{p}{[}\PYG{l+m+mi}{0}\PYG{p}{])}

            \PYG{c+c1}{\PYGZsh{} Add small controlled perturbation}
            \PYG{c+c1}{\PYGZsh{} This makes the task slightly harder and more realistic}
            \PYG{n}{noise\PYGZus{}val} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{randint}\PYG{p}{(}\PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{1}\PYG{p}{,} \PYG{l+m+mi}{2}\PYG{p}{,} \PYG{n}{right}\PYG{o}{.}\PYG{n}{shape}\PYG{p}{)}
            \PYG{n}{right} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{clamp}\PYG{p}{(}\PYG{n}{right} \PYG{o}{+} \PYG{n}{noise\PYGZus{}val}\PYG{p}{,} \PYG{l+m+mi}{1}\PYG{p}{,} \PYG{n}{vocab\PYGZus{}size} \PYG{o}{\PYGZhy{}} \PYG{l+m+mi}{1}\PYG{p}{)}

            \PYG{n}{label} \PYG{o}{=} \PYG{l+m+mi}{1}

        \PYG{k}{else}\PYG{p}{:}
            \PYG{c+c1}{\PYGZsh{} Negative Sample (Random)}
            \PYG{c+c1}{\PYGZsh{} Generate completely random right half}
            \PYG{n}{right} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{randint}\PYG{p}{(}\PYG{l+m+mi}{1}\PYG{p}{,} \PYG{n}{vocab\PYGZus{}size}\PYG{p}{,} \PYG{p}{(}\PYG{n}{half\PYGZus{}len}\PYG{p}{,))}
            \PYG{n}{label} \PYG{o}{=} \PYG{l+m+mi}{0}

        \PYG{c+c1}{\PYGZsh{} Final format: [left | noise | right]}
        \PYG{n}{seq} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{cat}\PYG{p}{([}\PYG{n}{left}\PYG{p}{,} \PYG{n}{noise}\PYG{p}{,} \PYG{n}{right}\PYG{p}{])}

        \PYG{n}{sequences}\PYG{o}{.}\PYG{n}{append}\PYG{p}{(}\PYG{n}{seq}\PYG{p}{)}
        \PYG{n}{labels}\PYG{o}{.}\PYG{n}{append}\PYG{p}{(}\PYG{n}{label}\PYG{p}{)}

    \PYG{n}{combined} \PYG{o}{=} \PYG{n+nb}{list}\PYG{p}{(}\PYG{n+nb}{zip}\PYG{p}{(}\PYG{n}{sequences}\PYG{p}{,} \PYG{n}{labels}\PYG{p}{))}
    \PYG{n}{random}\PYG{o}{.}\PYG{n}{shuffle}\PYG{p}{(}\PYG{n}{combined}\PYG{p}{)}
    \PYG{n}{sequences}\PYG{p}{,} \PYG{n}{labels} \PYG{o}{=} \PYG{n+nb}{zip}\PYG{p}{(}\PYG{o}{*}\PYG{n}{combined}\PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} Convert labels to tensor}
    \PYG{n}{labels} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{tensor}\PYG{p}{(}\PYG{n}{labels}\PYG{p}{,} \PYG{n}{dtype}\PYG{o}{=}\PYG{n}{torch}\PYG{o}{.}\PYG{n}{long}\PYG{p}{)}

    \PYG{k}{return} \PYG{n+nb}{list}\PYG{p}{(}\PYG{n}{sequences}\PYG{p}{),} \PYG{n}{labels}

\PYG{k+kn}{from}\PYG{+w}{ }\PYG{n+nn}{torch.utils.data}\PYG{+w}{ }\PYG{k+kn}{import} \PYG{n}{Dataset}\PYG{p}{,} \PYG{n}{DataLoader}

\PYG{k}{class}\PYG{+w}{ }\PYG{n+nc}{SequenceDataset}\PYG{p}{(}\PYG{n}{Dataset}\PYG{p}{):}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{    Custom PyTorch Dataset for handling variable\PYGZhy{}length sequence data.}

\PYG{l+s+sd}{    This dataset stores:}
\PYG{l+s+sd}{        \PYGZhy{} sequences : list of token sequences (each sequence is a tensor)}
\PYG{l+s+sd}{        \PYGZhy{} labels    : corresponding class labels for each sequence}

\PYG{l+s+sd}{    It allows PyTorch DataLoader to efficiently sample and batch data}
\PYG{l+s+sd}{    during training and evaluation.}
\PYG{l+s+sd}{    \PYGZdq{}\PYGZdq{}\PYGZdq{}}

    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf+fm}{\PYGZus{}\PYGZus{}init\PYGZus{}\PYGZus{}}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{sequences}\PYG{p}{,} \PYG{n}{labels}\PYG{p}{):}
        
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{sequences} \PYG{o}{=} \PYG{n}{sequences}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{labels} \PYG{o}{=} \PYG{n}{labels}

    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf+fm}{\PYGZus{}\PYGZus{}getitem\PYGZus{}\PYGZus{}}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{idx}\PYG{p}{):}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{        idx : Index of the sample.}

\PYG{l+s+sd}{        Returns}
\PYG{l+s+sd}{        sequence : Token sequence at index idx.}

\PYG{l+s+sd}{        label : Class label corresponding to the sequence.}
\PYG{l+s+sd}{        \PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{k}{return} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{sequences}\PYG{p}{[}\PYG{n}{idx}\PYG{p}{],} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{labels}\PYG{p}{[}\PYG{n}{idx}\PYG{p}{]}

    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf+fm}{\PYGZus{}\PYGZus{}len\PYGZus{}\PYGZus{}}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{):}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{        Return the total number of samples in the dataset.}
\PYG{l+s+sd}{        This allows DataLoader to know how many items exist.}
\PYG{l+s+sd}{        \PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{k}{return} \PYG{n+nb}{len}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{labels}\PYG{p}{)}


\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{collate\PYGZus{}fn}\PYG{p}{(}\PYG{n}{batch}\PYG{p}{):}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{    Custom collate function used by DataLoader to create batches.}

\PYG{l+s+sd}{    Since sequences have variable lengths, they cannot be directly stacked}
\PYG{l+s+sd}{    into a tensor. This function:}
\PYG{l+s+sd}{        1. Extracts sequences and labels from the batch}
\PYG{l+s+sd}{        2. Computes the true length of each sequence}
\PYG{l+s+sd}{        3. Pads sequences to the same length}
\PYG{l+s+sd}{        4. Returns tensors suitable for RNN/LSTM models}
\PYG{l+s+sd}{    \PYGZdq{}\PYGZdq{}\PYGZdq{}}

    \PYG{c+c1}{\PYGZsh{} Separate sequences and labels from the batch}
    \PYG{n}{sequences}\PYG{p}{,} \PYG{n}{labels} \PYG{o}{=} \PYG{n+nb}{zip}\PYG{p}{(}\PYG{o}{*}\PYG{n}{batch}\PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} Compute original sequence lengths before padding}
    \PYG{n}{lengths} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{tensor}\PYG{p}{([}\PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{seq}\PYG{p}{)} \PYG{k}{for} \PYG{n}{seq} \PYG{o+ow}{in} \PYG{n}{sequences}\PYG{p}{],} \PYG{n}{dtype}\PYG{o}{=}\PYG{n}{torch}\PYG{o}{.}\PYG{n}{long}\PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} Pad sequences so they all have the same length}
    \PYG{c+c1}{\PYGZsh{} padding\PYGZus{}value=0 corresponds to the padding token}
    \PYG{n}{padded} \PYG{o}{=} \PYG{n}{nn}\PYG{o}{.}\PYG{n}{utils}\PYG{o}{.}\PYG{n}{rnn}\PYG{o}{.}\PYG{n}{pad\PYGZus{}sequence}\PYG{p}{(}
        \PYG{n}{sequences}\PYG{p}{,}
        \PYG{n}{batch\PYGZus{}first}\PYG{o}{=}\PYG{k+kc}{True}\PYG{p}{,}
        \PYG{n}{padding\PYGZus{}value}\PYG{o}{=}\PYG{l+m+mi}{0}
    \PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} Convert labels to tensor}
    \PYG{n}{labels} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{tensor}\PYG{p}{(}\PYG{n}{labels}\PYG{p}{,} \PYG{n}{dtype}\PYG{o}{=}\PYG{n}{torch}\PYG{o}{.}\PYG{n}{long}\PYG{p}{)}

    \PYG{k}{return} \PYG{n}{padded}\PYG{p}{,} \PYG{n}{lengths}\PYG{p}{,} \PYG{n}{labels}

\PYG{n}{sequences}\PYG{p}{,} \PYG{n}{labels} \PYG{o}{=} \PYG{n}{generate\PYGZus{}balanced\PYGZus{}symmetric\PYGZus{}dataset}\PYG{p}{(}
    \PYG{n}{num\PYGZus{}samples}\PYG{o}{=}\PYG{l+m+mi}{10000}\PYG{p}{,}
    \PYG{n}{vocab\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mi}{60}
\PYG{p}{)}

\PYG{n}{X\PYGZus{}train}\PYG{p}{,} \PYG{n}{X\PYGZus{}val}\PYG{p}{,} \PYG{n}{y\PYGZus{}train}\PYG{p}{,} \PYG{n}{y\PYGZus{}val} \PYG{o}{=} \PYG{n}{train\PYGZus{}test\PYGZus{}split}\PYG{p}{(}
        \PYG{n}{sequences}\PYG{p}{,}
        \PYG{n}{labels}\PYG{p}{,}
        \PYG{n}{test\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mf}{0.2}\PYG{p}{,}
        \PYG{n}{stratify}\PYG{o}{=}\PYG{n}{labels}\PYG{p}{,}
        \PYG{n}{random\PYGZus{}state}\PYG{o}{=}\PYG{l+m+mi}{42}
    \PYG{p}{)}

\PYG{n}{train\PYGZus{}ds} \PYG{o}{=} \PYG{n}{SequenceDataset}\PYG{p}{(}\PYG{n}{X\PYGZus{}train}\PYG{p}{,} \PYG{n}{y\PYGZus{}train}\PYG{p}{)}
\PYG{n}{val\PYGZus{}ds} \PYG{o}{=} \PYG{n}{SequenceDataset}\PYG{p}{(}\PYG{n}{X\PYGZus{}val}\PYG{p}{,} \PYG{n}{y\PYGZus{}val}\PYG{p}{)}

\PYG{n}{train\PYGZus{}loader} \PYG{o}{=} \PYG{n}{DataLoader}\PYG{p}{(}
    \PYG{n}{train\PYGZus{}ds}\PYG{p}{,} \PYG{n}{batch\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mi}{32}\PYG{p}{,} \PYG{n}{shuffle}\PYG{o}{=}\PYG{k+kc}{True}\PYG{p}{,} \PYG{n}{collate\PYGZus{}fn}\PYG{o}{=}\PYG{n}{collate\PYGZus{}fn}
\PYG{p}{)}
\PYG{n}{val\PYGZus{}loader} \PYG{o}{=} \PYG{n}{DataLoader}\PYG{p}{(}
    \PYG{n}{val\PYGZus{}ds}\PYG{p}{,} \PYG{n}{batch\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mi}{32}\PYG{p}{,} \PYG{n}{shuffle}\PYG{o}{=}\PYG{k+kc}{False}\PYG{p}{,} \PYG{n}{collate\PYGZus{}fn}\PYG{o}{=}\PYG{n}{collate\PYGZus{}fn}
\PYG{p}{)}

