        \PYG{n}{dh2} \PYG{o}{=} \PYG{n}{dh} \PYG{o}{**} \PYG{l+m+mi}{2}           \PYG{c+c1}{\PYGZsh{} [B, H]}

        \PYG{c+c1}{\PYGZsh{} penalty\PYGZus{}per\PYGZus{}unit[b, i] = (h\PYGZus{}i(1 \PYGZhy{} h\PYGZus{}i))\PYGZca{}2 * ||W\PYGZus{}i||\PYGZus{}2\PYGZca{}2}
        \PYG{n}{penalty\PYGZus{}per\PYGZus{}unit} \PYG{o}{=} \PYG{n}{dh2} \PYG{o}{*} \PYG{n}{row\PYGZus{}norm\PYGZus{}squared}  \PYG{c+c1}{\PYGZsh{} [B, H]}

