        \PYG{n}{lambda\PYGZus{}c}\PYG{o}{=}\PYG{l+m+mf}{1e\PYGZhy{}2}
    \PYG{p}{):}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
