    \PYG{k}{return} \PYG{n}{e\PYGZus{}x} \PYG{o}{/} \PYG{n}{np}\PYG{o}{.}\PYG{n}{sum}\PYG{p}{(}\PYG{n}{e\PYGZus{}x}\PYG{p}{,} \PYG{n}{axis}\PYG{o}{=\PYGZhy{}}\PYG{l+m+mi}{1}\PYG{p}{,} \PYG{n}{keepdims}\PYG{o}{=}\PYG{k+kc}{True}\PYG{p}{)}

\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{cross\PYGZus{}entropy\PYGZus{}loss}\PYG{p}{(}\PYG{n}{probs}\PYG{p}{,} \PYG{n}{y\PYGZus{}true}\PYG{p}{):}
    \PYG{n}{n\PYGZus{}samples} \PYG{o}{=} \PYG{n}{y\PYGZus{}true}\PYG{o}{.}\PYG{n}{shape}\PYG{p}{[}\PYG{l+m+mi}{0}\PYG{p}{]}
    \PYG{n}{log\PYGZus{}likelihood} \PYG{o}{=} \PYG{o}{\PYGZhy{}}\PYG{n}{np}\PYG{o}{.}\PYG{n}{log}\PYG{p}{(}\PYG{n}{probs}\PYG{p}{[}\PYG{n+nb}{range}\PYG{p}{(}\PYG{n}{n\PYGZus{}samples}\PYG{p}{),} \PYG{n}{y\PYGZus{}true}\PYG{p}{]} \PYG{o}{+} \PYG{l+m+mf}{1e\PYGZhy{}9}\PYG{p}{)}
    \PYG{n}{loss} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{sum}\PYG{p}{(}\PYG{n}{log\PYGZus{}likelihood}\PYG{p}{)} \PYG{o}{/} \PYG{n}{n\PYGZus{}samples}

