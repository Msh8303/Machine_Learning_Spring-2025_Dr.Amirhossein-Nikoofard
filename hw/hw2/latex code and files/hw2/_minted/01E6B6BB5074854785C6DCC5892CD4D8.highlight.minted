\PYG{l+s+sd}{        \PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{c+c1}{\PYGZsh{} Encoder weights W have shape [hidden\PYGZus{}dim, input\PYGZus{}dim]}
