\PYG{l+s+sd}{        \PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{c+c1}{\PYGZsh{} Encode with noise (denoising behavior)}
        \PYG{n}{h}\PYG{p}{,} \PYG{n}{x\PYGZus{}noisy}\PYG{p}{,} \PYG{n}{u} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{encode}\PYG{p}{(}\PYG{n}{x}\PYG{p}{,} \PYG{n}{add\PYGZus{}noise}\PYG{o}{=}\PYG{k+kc}{True}\PYG{p}{)}

        \PYG{c+c1}{\PYGZsh{} Decode}
        \PYG{n}{x\PYGZus{}hat} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{decode}\PYG{p}{(}\PYG{n}{h}\PYG{p}{)}

        \PYG{c+c1}{\PYGZsh{} Reconstruction loss (MSE)}
        \PYG{n}{recon\PYGZus{}loss} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{mean}\PYG{p}{((}\PYG{n}{x\PYGZus{}hat} \PYG{o}{\PYGZhy{}} \PYG{n}{x}\PYG{p}{)} \PYG{o}{**} \PYG{l+m+mi}{2}\PYG{p}{)}

        \PYG{c+c1}{\PYGZsh{} Contractive penalty (Jacobian Frobenius norm)}
        \PYG{n}{contr\PYGZus{}penalty} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{contractive\PYGZus{}penalty}\PYG{p}{(}\PYG{n}{h}\PYG{p}{)}

        \PYG{c+c1}{\PYGZsh{} Total loss}
        \PYG{n}{total\PYGZus{}loss} \PYG{o}{=} \PYG{n}{recon\PYGZus{}loss} \PYG{o}{+} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{lambda\PYGZus{}c} \PYG{o}{*} \PYG{n}{contr\PYGZus{}penalty}

        \PYG{k}{return} \PYG{n}{total\PYGZus{}loss}\PYG{p}{,} \PYG{n}{recon\PYGZus{}loss}\PYG{p}{,} \PYG{n}{contr\PYGZus{}penalty}
\end{MintedVerbatim}
