\PYG{l+s+sd}{    Single\PYGZhy{}layer Contractive (Denoising) Autoencoder with Sigmoid encoder.}

\PYG{l+s+sd}{    Encoder:}
\PYG{l+s+sd}{        h = sigmoid(W x\PYGZus{}noisy + b)}

\PYG{l+s+sd}{    Decoder:}
\PYG{l+s+sd}{        x\PYGZus{}hat = decoder(h)   (here: a simple linear layer)}

\PYG{l+s+sd}{    Contractive penalty:}
\PYG{l+s+sd}{        For encoder f\PYGZus{}theta(x) = h = sigma(Wx + b),}
\PYG{l+s+sd}{        the Jacobian J\PYGZus{}f(x) has entries:}
\PYG{l+s+sd}{            J\PYGZus{}ij = ∂h\PYGZus{}i / ∂x\PYGZus{}j = sigma\PYGZsq{}(u\PYGZus{}i) * W\PYGZus{}ij}
\PYG{l+s+sd}{        where u = Wx + b and sigma\PYGZsq{}(u\PYGZus{}i) = h\PYGZus{}i (1 \PYGZhy{} h\PYGZus{}i).}

\PYG{l+s+sd}{        Thus:}
\PYG{l+s+sd}{            ||J\PYGZus{}f(x)||\PYGZus{}F\PYGZca{}2 = sum\PYGZus{}i (sigma\PYGZsq{}(u\PYGZus{}i))\PYGZca{}2 * ||W\PYGZus{}i||\PYGZus{}2\PYGZca{}2}
\PYG{l+s+sd}{                            = sum\PYGZus{}i (h\PYGZus{}i (1 \PYGZhy{} h\PYGZus{}i))\PYGZca{}2 * ||W\PYGZus{}i||\PYGZus{}2\PYGZca{}2}

\PYG{l+s+sd}{        We compute this analytically without forming the full Jacobian.}
\PYG{l+s+sd}{    \PYGZdq{}\PYGZdq{}\PYGZdq{}}

    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf+fm}{\PYGZus{}\PYGZus{}init\PYGZus{}\PYGZus{}}\PYG{p}{(}
