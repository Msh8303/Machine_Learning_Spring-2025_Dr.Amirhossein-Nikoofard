\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{generate\PYGZus{}data}\PYG{p}{(}\PYG{n}{num\PYGZus{}samples}\PYG{p}{,} \PYG{n}{seq\PYGZus{}len}\PYG{p}{):}
