        \PYG{k}{if} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{noise\PYGZus{}std} \PYG{o}{\PYGZlt{}=} \PYG{l+m+mf}{0.0}\PYG{p}{:}
            \PYG{k}{return} \PYG{n}{x}
