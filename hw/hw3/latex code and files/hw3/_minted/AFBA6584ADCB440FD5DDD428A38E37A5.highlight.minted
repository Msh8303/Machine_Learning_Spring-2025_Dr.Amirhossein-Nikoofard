\PYG{p}{\PYGZcb{},} \PYG{n}{index}\PYG{o}{=}\PYG{p}{[}\PYG{l+s+s1}{\PYGZsq{}Class 0\PYGZsq{}}\PYG{p}{,} \PYG{l+s+s1}{\PYGZsq{}Class 1\PYGZsq{}}\PYG{p}{])}

