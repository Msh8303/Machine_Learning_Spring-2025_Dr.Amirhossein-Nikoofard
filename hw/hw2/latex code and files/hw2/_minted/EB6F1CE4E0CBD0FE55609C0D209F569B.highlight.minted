        \PYG{n}{h\PYGZus{}int} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{clamp}\PYG{p}{(}\PYG{n}{y2\PYGZus{}int} \PYG{o}{\PYGZhy{}} \PYG{n}{y1\PYGZus{}int}\PYG{p}{,} \PYG{n+nb}{min}\PYG{o}{=}\PYG{l+m+mi}{0}\PYG{p}{)}
        \PYG{n}{I} \PYG{o}{=} \PYG{n}{w\PYGZus{}int} \PYG{o}{*} \PYG{n}{h\PYGZus{}int}

