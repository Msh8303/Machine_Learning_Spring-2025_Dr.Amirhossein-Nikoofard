        \PYG{n}{y1\PYGZus{}int} \PYG{o}{=} \PYG{n}{torch}\PYG{o}{.}\PYG{n}{max}\PYG{p}{(}\PYG{n}{y1\PYGZus{}p}\PYG{p}{,} \PYG{n}{y1\PYGZus{}g}\PYG{p}{)}
