    \PYG{n}{rnn} \PYG{o}{=} \PYG{n}{BatchedVanillaRNN}\PYG{p}{(}\PYG{n}{FEATURES}\PYG{p}{,} \PYG{n}{HIDDEN\PYGZus{}SIZE}\PYG{p}{,} \PYG{n}{OUTPUT\PYGZus{}SIZE}\PYG{p}{)}

