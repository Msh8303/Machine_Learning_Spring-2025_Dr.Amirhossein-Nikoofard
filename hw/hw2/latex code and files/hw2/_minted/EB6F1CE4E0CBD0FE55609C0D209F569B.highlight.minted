        \PYG{n}{noobj\PYGZus{}mask} \PYG{o}{=} \PYG{l+m+mi}{1} \PYG{o}{\PYGZhy{}} \PYG{n}{obj\PYGZus{}mask}

        \PYG{c+c1}{\PYGZsh{} 1) Localization loss using DiceBox}
