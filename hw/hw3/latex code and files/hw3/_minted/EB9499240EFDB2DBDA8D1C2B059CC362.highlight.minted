\PYG{k+kn}{import}\PYG{+w}{ }\PYG{n+nn}{numpy}\PYG{+w}{ }\PYG{k}{as}\PYG{+w}{ }\PYG{n+nn}{np}

\PYG{k}{class}\PYG{+w}{ }\PYG{n+nc}{CIFG\PYGZus{}LSTM}\PYG{p}{:}
    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf+fm}{\PYGZus{}\PYGZus{}init\PYGZus{}\PYGZus{}}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{input\PYGZus{}size}\PYG{p}{,} \PYG{n}{hidden\PYGZus{}size}\PYG{p}{):}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{        Initialize network parameters}
\PYG{l+s+sd}{        input\PYGZus{}size: dimension of the input vector at each time step}
\PYG{l+s+sd}{        hidden\PYGZus{}size: dimension of the hidden state (memory)}
\PYG{l+s+sd}{        \PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{input\PYGZus{}size} \PYG{o}{=} \PYG{n}{input\PYGZus{}size}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{hidden\PYGZus{}size} \PYG{o}{=} \PYG{n}{hidden\PYGZus{}size}

        \PYG{c+c1}{\PYGZsh{} Initialize weights with a normal distribution and biases with zeros}
        \PYG{c+c1}{\PYGZsh{} W: weights connected to input X}
        \PYG{c+c1}{\PYGZsh{} U: weights connected to previous hidden state h}
        \PYG{c+c1}{\PYGZsh{} b: biases}

        \PYG{c+c1}{\PYGZsh{} 1. Input Gate parameters}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{Wi} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{random}\PYG{o}{.}\PYG{n}{randn}\PYG{p}{(}\PYG{n}{hidden\PYGZus{}size}\PYG{p}{,} \PYG{n}{input\PYGZus{}size}\PYG{p}{)} \PYG{o}{*} \PYG{l+m+mf}{0.1}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{Ui} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{random}\PYG{o}{.}\PYG{n}{randn}\PYG{p}{(}\PYG{n}{hidden\PYGZus{}size}\PYG{p}{,} \PYG{n}{hidden\PYGZus{}size}\PYG{p}{)} \PYG{o}{*} \PYG{l+m+mf}{0.1}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{bi} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{zeros}\PYG{p}{((}\PYG{n}{hidden\PYGZus{}size}\PYG{p}{,} \PYG{l+m+mi}{1}\PYG{p}{))}

        \PYG{c+c1}{\PYGZsh{} 2. Candidate Cell State parameters}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{Wc} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{random}\PYG{o}{.}\PYG{n}{randn}\PYG{p}{(}\PYG{n}{hidden\PYGZus{}size}\PYG{p}{,} \PYG{n}{input\PYGZus{}size}\PYG{p}{)} \PYG{o}{*} \PYG{l+m+mf}{0.1}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{Uc} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{random}\PYG{o}{.}\PYG{n}{randn}\PYG{p}{(}\PYG{n}{hidden\PYGZus{}size}\PYG{p}{,} \PYG{n}{hidden\PYGZus{}size}\PYG{p}{)} \PYG{o}{*} \PYG{l+m+mf}{0.1}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{bc} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{zeros}\PYG{p}{((}\PYG{n}{hidden\PYGZus{}size}\PYG{p}{,} \PYG{l+m+mi}{1}\PYG{p}{))}

        \PYG{c+c1}{\PYGZsh{} 3. Output Gate parameters}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{Wo} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{random}\PYG{o}{.}\PYG{n}{randn}\PYG{p}{(}\PYG{n}{hidden\PYGZus{}size}\PYG{p}{,} \PYG{n}{input\PYGZus{}size}\PYG{p}{)} \PYG{o}{*} \PYG{l+m+mf}{0.1}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{Uo} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{random}\PYG{o}{.}\PYG{n}{randn}\PYG{p}{(}\PYG{n}{hidden\PYGZus{}size}\PYG{p}{,} \PYG{n}{hidden\PYGZus{}size}\PYG{p}{)} \PYG{o}{*} \PYG{l+m+mf}{0.1}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{bo} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{zeros}\PYG{p}{((}\PYG{n}{hidden\PYGZus{}size}\PYG{p}{,} \PYG{l+m+mi}{1}\PYG{p}{))}

    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{\PYGZus{}sigmoid}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{x}\PYG{p}{):}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}Sigmoid activation function producing output between 0 and 1\PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{c+c1}{\PYGZsh{} Prevent numerical overflow}
        \PYG{n}{x} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{clip}\PYG{p}{(}\PYG{n}{x}\PYG{p}{,} \PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{500}\PYG{p}{,} \PYG{l+m+mi}{500}\PYG{p}{)}
        \PYG{k}{return} \PYG{l+m+mf}{1.0} \PYG{o}{/} \PYG{p}{(}\PYG{l+m+mf}{1.0} \PYG{o}{+} \PYG{n}{np}\PYG{o}{.}\PYG{n}{exp}\PYG{p}{(}\PYG{o}{\PYGZhy{}}\PYG{n}{x}\PYG{p}{))}

    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{\PYGZus{}tanh}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{x}\PYG{p}{):}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}Hyperbolic tangent activation function producing output between \PYGZhy{}1 and 1\PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{k}{return} \PYG{n}{np}\PYG{o}{.}\PYG{n}{tanh}\PYG{p}{(}\PYG{n}{x}\PYG{p}{)}

    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{forward\PYGZus{}step}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{x\PYGZus{}t}\PYG{p}{,} \PYG{n}{h\PYGZus{}prev}\PYG{p}{,} \PYG{n}{c\PYGZus{}prev}\PYG{p}{):}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{        Perform the forward pass for a single time step}
\PYG{l+s+sd}{        x\PYGZus{}t: input at time t with shape (input\PYGZus{}size, 1)}
\PYG{l+s+sd}{        h\PYGZus{}prev: previous hidden state with shape (hidden\PYGZus{}size, 1)}
\PYG{l+s+sd}{        c\PYGZus{}prev: previous cell state with shape (hidden\PYGZus{}size, 1)}
\PYG{l+s+sd}{        \PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{c+c1}{\PYGZsh{} 1. Compute input gate (i\PYGZus{}t)}
        \PYG{n}{i\PYGZus{}t} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{\PYGZus{}sigmoid}\PYG{p}{(}\PYG{n}{np}\PYG{o}{.}\PYG{n}{dot}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{Wi}\PYG{p}{,} \PYG{n}{x\PYGZus{}t}\PYG{p}{)} \PYG{o}{+} \PYG{n}{np}\PYG{o}{.}\PYG{n}{dot}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{Ui}\PYG{p}{,} \PYG{n}{h\PYGZus{}prev}\PYG{p}{)} \PYG{o}{+} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{bi}\PYG{p}{)}

        \PYG{c+c1}{\PYGZsh{} Forget gate is implicitly defined as (1 \PYGZhy{} i\PYGZus{}t)}
        \PYG{n}{f\PYGZus{}t} \PYG{o}{=} \PYG{l+m+mf}{1.0} \PYG{o}{\PYGZhy{}} \PYG{n}{i\PYGZus{}t}

        \PYG{c+c1}{\PYGZsh{} 2. Compute candidate cell state (c\PYGZus{}tilde\PYGZus{}t)}
        \PYG{n}{c\PYGZus{}tilde\PYGZus{}t} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{\PYGZus{}tanh}\PYG{p}{(}\PYG{n}{np}\PYG{o}{.}\PYG{n}{dot}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{Wc}\PYG{p}{,} \PYG{n}{x\PYGZus{}t}\PYG{p}{)} \PYG{o}{+} \PYG{n}{np}\PYG{o}{.}\PYG{n}{dot}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{Uc}\PYG{p}{,} \PYG{n}{h\PYGZus{}prev}\PYG{p}{)} \PYG{o}{+} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{bc}\PYG{p}{)}

        \PYG{c+c1}{\PYGZsh{} 3. Update the cell state (C\PYGZus{}t) using the given formula}
        \PYG{c+c1}{\PYGZsh{} Ct = (1 − it) ⊙ Ct−1 + it ⊙ C˜t}
        \PYG{n}{c\PYGZus{}t} \PYG{o}{=} \PYG{n}{f\PYGZus{}t} \PYG{o}{*} \PYG{n}{c\PYGZus{}prev} \PYG{o}{+} \PYG{n}{i\PYGZus{}t} \PYG{o}{*} \PYG{n}{c\PYGZus{}tilde\PYGZus{}t}  \PYG{c+c1}{\PYGZsh{} In NumPy, * means element\PYGZhy{}wise multiplication}

        \PYG{c+c1}{\PYGZsh{} 4. Compute output gate (o\PYGZus{}t)}
        \PYG{n}{o\PYGZus{}t} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{\PYGZus{}sigmoid}\PYG{p}{(}\PYG{n}{np}\PYG{o}{.}\PYG{n}{dot}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{Wo}\PYG{p}{,} \PYG{n}{x\PYGZus{}t}\PYG{p}{)} \PYG{o}{+} \PYG{n}{np}\PYG{o}{.}\PYG{n}{dot}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{Uo}\PYG{p}{,} \PYG{n}{h\PYGZus{}prev}\PYG{p}{)} \PYG{o}{+} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{bo}\PYG{p}{)}

        \PYG{c+c1}{\PYGZsh{} 5. Compute the new hidden state (h\PYGZus{}t)}
        \PYG{n}{h\PYGZus{}t} \PYG{o}{=} \PYG{n}{o\PYGZus{}t} \PYG{o}{*} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{\PYGZus{}tanh}\PYG{p}{(}\PYG{n}{c\PYGZus{}t}\PYG{p}{)}

        \PYG{k}{return} \PYG{n}{h\PYGZus{}t}\PYG{p}{,} \PYG{n}{c\PYGZus{}t}

    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{forward}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{X}\PYG{p}{):}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{        Perform the forward pass for a full input sequence}
\PYG{l+s+sd}{        X: input sequence with shape (sequence\PYGZus{}length, input\PYGZus{}size)}
\PYG{l+s+sd}{        \PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{n}{seq\PYGZus{}length} \PYG{o}{=} \PYG{n}{X}\PYG{o}{.}\PYG{n}{shape}\PYG{p}{[}\PYG{l+m+mi}{0}\PYG{p}{]}

        \PYG{c+c1}{\PYGZsh{} Initialize memory states with zeros}
        \PYG{n}{h\PYGZus{}t} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{zeros}\PYG{p}{((}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{hidden\PYGZus{}size}\PYG{p}{,} \PYG{l+m+mi}{1}\PYG{p}{))}
        \PYG{n}{c\PYGZus{}t} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{zeros}\PYG{p}{((}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{hidden\PYGZus{}size}\PYG{p}{,} \PYG{l+m+mi}{1}\PYG{p}{))}

        \PYG{c+c1}{\PYGZsh{} List to store all hidden states over time}
        \PYG{n}{hidden\PYGZus{}states} \PYG{o}{=} \PYG{p}{[]}

        \PYG{c+c1}{\PYGZsh{} Loop through time steps}
        \PYG{k}{for} \PYG{n}{t} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{n}{seq\PYGZus{}length}\PYG{p}{):}
            \PYG{c+c1}{\PYGZsh{} Reshape the t\PYGZhy{}th input into a column vector (input\PYGZus{}size, 1)}
            \PYG{n}{x\PYGZus{}t} \PYG{o}{=} \PYG{n}{X}\PYG{p}{[}\PYG{n}{t}\PYG{p}{]}\PYG{o}{.}\PYG{n}{reshape}\PYG{p}{(}\PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{1}\PYG{p}{,} \PYG{l+m+mi}{1}\PYG{p}{)}

            \PYG{c+c1}{\PYGZsh{} Run one LSTM step}
            \PYG{n}{h\PYGZus{}t}\PYG{p}{,} \PYG{n}{c\PYGZus{}t} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{forward\PYGZus{}step}\PYG{p}{(}\PYG{n}{x\PYGZus{}t}\PYG{p}{,} \PYG{n}{h\PYGZus{}t}\PYG{p}{,} \PYG{n}{c\PYGZus{}t}\PYG{p}{)}

            \PYG{c+c1}{\PYGZsh{} Store output}
            \PYG{n}{hidden\PYGZus{}states}\PYG{o}{.}\PYG{n}{append}\PYG{p}{(}\PYG{n}{h\PYGZus{}t}\PYG{o}{.}\PYG{n}{flatten}\PYG{p}{())}

        \PYG{k}{return} \PYG{n}{np}\PYG{o}{.}\PYG{n}{array}\PYG{p}{(}\PYG{n}{hidden\PYGZus{}states}\PYG{p}{)}


