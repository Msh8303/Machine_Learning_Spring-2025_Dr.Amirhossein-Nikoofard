        \PYG{c+c1}{\PYGZsh{} For each hidden unit i, compute ||W\PYGZus{}i||\PYGZus{}2\PYGZca{}2}
        \PYG{c+c1}{\PYGZsh{} row\PYGZus{}norm\PYGZus{}squared: [H]}
